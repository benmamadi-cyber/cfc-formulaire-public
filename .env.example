# ── Configuration de l'intermédiaire cloud CFC (formulaire public) ──
# Copier en .env et adapter avant déploiement sur le VPS (CAFCA).

# Jeton partagé avec l'application interne pour la synchronisation (pull).
# Générer une valeur robuste, ex :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# La MÊME valeur doit être configurée côté app interne (CAPTURE_TOKEN).
SYNC_TOKEN=

# Chemin du fichier SQLite (défaut : ./soumissions.db)
PUBLIC_DB_PATH=./soumissions.db

# Port d'écoute (défaut : 8080)
PORT=8080

# Débit maximal du formulaire public par IP (anti-spam). Défaut : 5 per hour
RATE_SOUMISSION=5 per hour
